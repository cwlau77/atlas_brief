# The backend is deployed separately on Render (see render.yaml), not as a
# Vercel Function. Without this file, Vercel's zero-config Python detection
# sees the root requirements.txt, scans for an ASGI entrypoint, finds
# backend/main.py's `app`, and fails the build demanding a pyproject.toml
# [tool.vercel] entrypoint — we don't want it deployed here at all.
backend/
requirements.txt
render.yaml
docs/
.venv/
.pytest_cache/
pytest.ini
