# Required for real synthesis (503 without it unless DEMO_MODE=true)
ANTHROPIC_API_KEY=
# Optional but strongly recommended — one of three ingestion sources
NEWSAPI_KEY=

# Comma-separated browser origins allowed by CORS ("*" for local dev)
ALLOWED_ORIGINS=*
# true = allow keyword-matched fallback briefings without an Anthropic key
DEMO_MODE=false
# Per-IP budget for POST /briefing; 0 disables
RATE_LIMIT_PER_MINUTE=6

GDELT_MIN_INTERVAL_SECONDS=5.5
MAX_ARTICLES_PER_SOURCE=15
DEDUP_SIMILARITY_THRESHOLD=0.85
RELEVANCE_SIMILARITY_THRESHOLD=0.30
HOURS_LOOKBACK=24
SYNTHESIS_MODEL=claude-haiku-4-5
CONTEXT_MODEL=claude-haiku-4-5
CACHE_TTL_MINUTES=15
CONTEXT_ENRICHMENT_LIMIT=4
